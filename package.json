{
  "name": "tododsl",
  "version": "1.0.0",
  "description": "Tag-based HTML extension DSL runtime with full-stack support",
  "main": "dist/index.js",
  "bin": {
    "tododsl": "dist/cli.js"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/cli.js",
    "link:global": "npm run build && npm link"
  },
  "keywords": [
    "dsl",
    "html",
    "todo",
    "compiler",
    "fullstack"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "body-parser": "^2.2.2",
    "cheerio": "^1.2.0",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.5",
    "@types/node": "^24.10.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
